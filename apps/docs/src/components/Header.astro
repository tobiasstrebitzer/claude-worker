---
import ThemeToggle from './ThemeToggle.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const repo = 'https://github.com/tobiasstrebitzer/claude-worker'
---

<header
  class="sticky top-0 z-40 border-b border-border bg-[var(--bg-elevated)] backdrop-blur"
>
  <div class="mx-auto flex h-14 max-w-7xl items-center gap-4 px-4 sm:px-6">
    <a href={`${base}/`} class="flex items-center gap-2.5 font-semibold tracking-tight">
      <svg
        viewBox="0 0 24 24"
        class="size-5"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M8 3.5h9A3.5 3.5 0 0 1 20.5 7v9"></path>
        <rect width="13.5" height="13.5" x="3.5" y="7" rx="3.5"></rect>
        <path d="m7 16.5 2.5-2.5L7 11.5"></path>
        <circle cx="13.2" cy="14" r="1.7" fill="#2fbf71" stroke="none"></circle>
      </svg>
      <span>claude-worker</span>
    </a>
    <nav class="ml-auto flex items-center gap-1 text-sm">
      <a
        href={`${base}/docs/getting-started/introduction/`}
        class="rounded-md px-3 py-1.5 font-medium text-fg-3 transition-colors hover:bg-surface-hover hover:text-fg-1"
        >Docs</a
      >
      <a
        href="https://www.npmjs.com/org/claude-worker"
        class="hidden rounded-md px-3 py-1.5 font-medium text-fg-3 transition-colors hover:bg-surface-hover hover:text-fg-1 sm:block"
        >npm</a
      >
      <a
        href={repo}
        aria-label="GitHub repository"
        class="rounded-md p-2 text-fg-3 transition-colors hover:bg-surface-hover hover:text-fg-1"
      >
        <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>
