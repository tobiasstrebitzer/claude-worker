{
  "name": "claude-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "description": "Run a close-to-real Claude Code session programmatically via the Agent SDK and expose it to a host app as something it can embed, watch, and control. Runner + wire protocol + gateway + embeddable panel. See docs/prd-claude-worker.md.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "oxlint",
    "clean": "turbo run clean",
    "demo": "pnpm --filter @claude-worker/demo run dev",
    "web": "pnpm --filter @claude-worker/web run dev",
    "server": "pnpm --filter @claude-worker/server run dev"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "oxlint": "^1.0.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10",
    "turbo": "^2.9.9",
    "vitest": "^3.2.0"
  }
}
