{
  "name": "@claude-worker/ui",
  "version": "0.1.1",
  "type": "module",
  "description": "Styled agent-control component library for claude-worker: session panel, transcript with streaming, tool-call cards, permission prompts, session list, composer. Tailwind v4 + Base UI + cva. Pairs with the headless @claude-worker/react layer.",
  "license": "MIT",
  "main": "./build/index.mjs",
  "types": "./build/index.d.mts",
  "files": [
    "build",
    "src"
  ],
  "exports": {
    ".": {
      "@claude-worker/source": "./src/index.ts",
      "types": "./build/index.d.mts",
      "default": "./build/index.mjs"
    },
    "./theme.css": "./src/styles/theme.css"
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "typecheck": "tsgo -p tsconfig.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@claude-worker/client": "workspace:*",
    "@claude-worker/protocol": "workspace:*",
    "@claude-worker/react": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "use-stick-to-bottom": "^1.1.6"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10"
  },
  "author": "Tobias Strebitzer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobiasstrebitzer/claude-worker.git",
    "directory": "packages/ui"
  },
  "homepage": "https://tobiasstrebitzer.github.io/claude-worker/",
  "bugs": "https://github.com/tobiasstrebitzer/claude-worker/issues",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "agent",
    "react",
    "components",
    "tailwind",
    "ui"
  ]
}
