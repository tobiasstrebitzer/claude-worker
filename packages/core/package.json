{
  "name": "@claude-worker/core",
  "version": "0.1.1",
  "type": "module",
  "description": "The claude-worker session runner: wraps the Agent SDK's query() with a push-based input queue, promotes canUseTool calls into pending approvals, normalizes SDKMessages into wire-protocol events, and keeps a seq-numbered event log for attach/replay. Pure library, no transport.",
  "license": "MIT",
  "main": "./build/index.mjs",
  "types": "./build/index.d.mts",
  "files": [
    "build"
  ],
  "exports": {
    ".": {
      "@claude-worker/source": "./src/index.ts",
      "types": "./build/index.d.mts",
      "default": "./build/index.mjs"
    }
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "typecheck": "tsgo -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.217",
    "@claude-worker/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10",
    "vitest": "^3.2.0"
  },
  "author": "Tobias Strebitzer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobiasstrebitzer/claude-worker.git",
    "directory": "packages/core"
  },
  "homepage": "https://tobiasstrebitzer.github.io/claude-worker/",
  "bugs": "https://github.com/tobiasstrebitzer/claude-worker/issues",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "agent",
    "agent-sdk",
    "session",
    "runner"
  ],
  "publishConfig": {
    "access": "public"
  }
}
