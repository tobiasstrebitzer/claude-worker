{
  "name": "@claude-worker/client",
  "version": "0.1.0",
  "type": "module",
  "description": "Typed claude-worker protocol client for browsers and Node: REST session management plus a WebSocket attach with auto-reconnect and replay-from-last-seq. Uses the platform's fetch and WebSocket; zero runtime deps.",
  "main": "./build/index.mjs",
  "types": "./build/index.d.mts",
  "files": ["build"],
  "exports": {
    ".": {
      "@claude-worker/source": "./src/index.ts",
      "types": "./build/index.d.mts",
      "default": "./build/index.mjs"
    }
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "typecheck": "tsgo -p tsconfig.json"
  },
  "dependencies": {
    "@claude-worker/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10"
  }
}
