{
  "name": "@claude-worker/server",
  "version": "0.1.0",
  "type": "module",
  "description": "The claude-worker gateway: HTTP + WebSocket session server over @claude-worker/core. Session registry (create/list/attach/interrupt/kill), pluggable auth hook, replay-from-seq attach. Runs anywhere Node runs — needs a real filesystem (no serverless).",
  "license": "MIT",
  "main": "./build/index.mjs",
  "types": "./build/index.d.mts",
  "files": [
    "build"
  ],
  "exports": {
    ".": {
      "@claude-worker/source": "./src/index.ts",
      "types": "./build/index.d.mts",
      "default": "./build/index.mjs"
    }
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "typecheck": "tsgo -p tsconfig.json",
    "test": "vitest run",
    "dev": "node --conditions=@claude-worker/source --import @swc-node/register/esm-register src/dev.ts"
  },
  "dependencies": {
    "@claude-worker/core": "workspace:*",
    "@claude-worker/protocol": "workspace:*",
    "@claude-worker/queue": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10",
    "vitest": "^3.2.0"
  },
  "author": "Tobias Strebitzer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobiasstrebitzer/claude-worker.git",
    "directory": "packages/server"
  },
  "homepage": "https://tobiasstrebitzer.github.io/claude-worker/",
  "bugs": "https://github.com/tobiasstrebitzer/claude-worker/issues",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "agent",
    "server",
    "websocket",
    "gateway"
  ]
}
